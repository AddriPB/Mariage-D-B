# Copier ce fichier en .env.production pour le build/deploiement, sans le commiter.
# Les valeurs VITE_FIREBASE_* sont publiques dans un build web Firebase.
# Ne jamais mettre de service account ou de secret serveur ici.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_ADMIN_AUTH_EMAIL_DOMAIN=
